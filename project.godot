; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="xiuxian2"
run/main_scene="res://scenes/PrototypeRoot.tscn"
config/features=PackedStringArray("4.5", "C#", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

ServiceLocator="*res://scripts/services/ServiceLocator.cs"
LevelConfigLoader="*res://scripts/services/LevelConfigLoader.cs"
InputActivityState="*res://scripts/services/InputActivityState.cs"
InputHookService="*res://scripts/services/InputHookService.cs"
InputPauseShortcut="*res://scripts/services/InputPauseShortcut.cs"
BackpackState="*res://scripts/services/BackpackState.cs"
AlchemyState="*res://scripts/services/AlchemyState.cs"
PotionInventoryState="*res://scripts/services/PotionInventoryState.cs"
SmithingState="*res://scripts/services/SmithingState.cs"
GardenState="*res://scripts/services/GardenState.cs"
MiningState="*res://scripts/services/MiningState.cs"
FishingState="*res://scripts/services/FishingState.cs"
TalismanState="*res://scripts/services/RecipeProgressState.cs"
CookingState="*res://scripts/services/RecipeProgressState.cs"
FormationState="*res://scripts/services/FormationState.cs"
EnlightenmentState="*res://scripts/services/RecipeProgressState.cs"
BodyCultivationState="*res://scripts/services/RecipeProgressState.cs"
ResourceWalletState="*res://scripts/services/ResourceWalletState.cs"
PlayerProgressState="*res://scripts/services/PlayerProgressState.cs"
PlayerActionState="*res://scripts/services/PlayerActionState.cs"
EquippedItemsState="*res://scripts/services/EquippedItemsState.cs"
SubsystemMasteryState="*res://scripts/services/SubsystemMasteryState.cs"
ActivityConversionService="*res://scripts/services/ActivityConversionService.cs"
CloudSaveSyncService="*res://scripts/services/CloudSaveSyncService.cs"

[display]

window/size/viewport_width=1152
window/size/viewport_height=648

[dotnet]

project/assembly_name="xiuxian2"
